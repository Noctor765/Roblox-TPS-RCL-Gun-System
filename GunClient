local function safeFindFirstChild(parent: Instance?, name: string, class: string): (Instance?)
	if not parent then warn("Parent not found. |", "Name of desired instance: ", name, "| ClassName of desired instance: ", class) return end
	
	for i, v in parent:GetChildren() do
		if v.Name == name and v.ClassName == class then
			return v
		end
	end
	return nil
end

local function drawBullet(startpos: Vector3, endpos: Vector3)
	local bullet = Instance.new("Part")
	bullet.Parent = BulletHolder
	bullet.Anchored = true
	bullet.Size = Vector3.new(0.2, 0.2, 0.4)
	bullet.CanCollide = false
	bullet.CanTouch = false
	bullet.CanQuery = false
	bullet.CastShadow = false
	bullet.Color = Color3.fromRGB(255, 255, 0)
	bullet.Material = Enum.Material.Neon
	bullet.Position = startpos
	bullet.CFrame = CFrame.new(startpos, endpos)
	TweenService:Create(bullet, BulletInfo, { Position = endpos }):Play()
	task.delay(0.03, function()
		bullet:Destroy()
		bullet = nil
	end)
end

local function sendBulletData(startpos: Vector3, endpos: Vector3, isHit: boolean, dmg: number?, human: Humanoid?)
	local buf = Create(24)
	WriteF32(buf, 0, startpos.X)
	WriteF32(buf, 4, startpos.Y)
	WriteF32(buf, 8, startpos.Z)
	WriteF32(buf, 12, endpos.X)
	WriteF32(buf, 16, endpos.Y)
	WriteF32(buf, 20, endpos.Z)
	if isHit then
		Event1:FireServer(buf, true, dmg, human)
	else
		Event1:FireServer(buf, false)
	end
end

Event1.OnClientEvent:Connect(function(plr: Player, buf: buffer)
	if plr == LocalPlayer then return end
	
	local x1 = ReadF32(buf, 0)
	local y1 = ReadF32(buf, 4)
	local z1 = ReadF32(buf, 8)
	local x2 = ReadF32(buf, 12)
	local y2 = ReadF32(buf, 16)
	local z2 = ReadF32(buf, 20)
	
	local startpos, endpos = Vector3.new(x1, y1, z1), Vector3.new(x2, y2, z2)
	drawBullet(startpos, endpos)
end)

local IgnoreList: { Instance } = { Character, BulletHolder }
const RaycastParam = RaycastParams.new()
RaycastParam.FilterDescendantsInstances = IgnoreList
RaycastParam.FilterType = Enum.RaycastFilterType.Exclude
RaycastParam.IgnoreWater = true

local function RemoveValue(obj: Accessory)
	for i, v in IgnoreList do
		if v == obj then
			Remove(IgnoreList, i)
			break
		end
	end
end

for _, v in Players:GetPlayers() do
	if v.Character then
		for i, p in v.Character:GetChildren() do
			if p:IsA("Accessory") then
				Insert(IgnoreList, p)
			end
		end
		RaycastParam.FilterDescendantsInstances = IgnoreList
	end
	
	v.CharacterAdded:Connect(function(char: Model)
		repeat task.wait() until char:FindFirstChildOfClass("Humanoid")
		
		for i, p in char:GetChildren() do
			if p:IsA("Accessory") then
				Insert(IgnoreList, p)
			end
		end
		RaycastParam.FilterDescendantsInstances = IgnoreList
	end)
	
	v.CharacterRemoving:Connect(function(char: Model)
		for i, p in char:GetChildren() do
			if p:IsA("Accessory") then
				RemoveValue(p)
			end
		end
		RaycastParam.FilterDescendantsInstances = IgnoreList
	end)
end

